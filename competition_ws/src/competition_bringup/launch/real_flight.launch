<launch>
  <!-- ============================================================================
  实机飞行启动 — 保守65分策略

  得分路线:
    任务1 起飞悬停            10分
    任务2 H→A 导航           10分
    任务6 颜色识别输出         15分
    竞速门1 穿越加分           +5分
    任务4 A→B 导航           10分
    任务7 按颜色降落          15分
  -------------------------------------------------------------------
  合计                       65分

  放弃: 任务3(抓取)、任务5(精准投放) — 减少风险
  ============================================================================ -->

  <!-- ===== 相机话题参数（按需修改） ===== -->
  <arg name="camera_topic"       default="/camera/color/image_raw"/>
  <arg name="depth_topic"        default="/camera/depth/image_rect_raw"/>
  <arg name="camera_info_topic"  default="/camera/color/camera_info"/>

  <!-- ===== 策略参数 ===== -->
  <arg name="conservative_mode" default="true"/>       <!-- 保守模式: 跳过抓取/投放, 穿门加分 -->
  <arg name="gripper_type"      default="electromagnet"/>
  <arg name="gripper_gpio"      default="18"/>

  <!-- ===== 1. 颜色检测节点 ===== -->
  <node name="vision_node" pkg="vision_node" type="vision_node" output="screen">
    <rosparam file="$(find vision_node)/config/color_params.yaml" command="load"/>
    <param name="camera_topic"      value="$(arg camera_topic)"/>
    <param name="depth_topic"       value="$(arg depth_topic)"/>
    <param name="camera_info_topic" value="$(arg camera_info_topic)"/>
  </node>

  <!-- ===== 2. 任务状态机 ===== -->
  <node name="mission_node" pkg="mission_node" type="mission_node" output="screen">
    <rosparam file="$(find competition_bringup)/config/map.yaml" command="load"/>
    <!-- 保守模式参数: 慢速、高容差、长悬停 -->
    <param name="conservative_mode" value="$(arg conservative_mode)"/>
    <param name="enable_grasp"      value="false"/>
    <param name="speed"             value="0.20"/>    <!-- 0.2m/s 慢速稳飞 -->
    <param name="tolerance"         value="0.40"/>    <!-- 0.4m 大容差 -->
    <param name="hover_duration"    value="8.0"/>     <!-- 悬停8秒确保合规 -->
    <param name="detect_timeout"    value="45.0"/>    <!-- 45秒颜色检测足够充裕 -->
  </node>

  <!-- ===== 3. 抓取机构控制节点 ===== -->
  <node name="gripper_node" pkg="gripper_node" type="gripper_node" output="screen">
    <param name="gripper_type" value="$(arg gripper_type)"/>
    <param name="gpio_pin"     value="$(arg gripper_gpio)"/>
  </node>

</launch>
